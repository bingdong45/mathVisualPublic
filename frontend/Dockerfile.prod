# Stage 1 — build the static site
FROM node:20-slim AS builder
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
ENV VITE_BASE_PATH=/
RUN npm run build

# Stage 2 — Caddy serves the built site + reverse-proxies /api and /media
FROM caddy:2-alpine
COPY --from=builder /app/dist /srv
