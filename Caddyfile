mathvisual.bingyixuan.com {
    encode zstd gzip

    # API + media go to the FastAPI backend
    handle /api/* {
        reverse_proxy backend:8000
    }
    handle /media/* {
        reverse_proxy backend:8000
    }

    # SPA: serve built static files, fall back to index.html for client-side routes
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}

visualcs.bingyixuan.com {
    encode zstd gzip
    reverse_proxy visualcs:3000
}
